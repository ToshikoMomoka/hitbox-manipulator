function farm.stop()
    st.ismainfarming = false
    st.isaltfarming = false
    togglehitbox(false)
    conns:remove("FarmTP")
    conns:remove("FarmAlt")
    conns:remove("FarmCharAdded")
end

function farm.startmain()
    farm.stop()
    st.ismainfarming = true
    st.farmalive = true
    togglehitbox(true)

    conns:add("FarmCharAdded", lp.CharacterAdded:Connect(function(c)
        if st.unloaded or not st.ismainfarming then return end
        st.farmalive = false
        c:WaitForChild("HumanoidRootPart", 5)
        task.wait(1.5)
        st.farmalive = true
    end))

    local t = task.spawn(function()
        while st.ismainfarming and not st.unloaded do
            pcall(farm.firedynamicm1)
            task.wait(0.12)
        end
    end)
    conns:trackthread(t)
end

function farm.startalt()
    if st.farmtargetname == "" then return end
    farm.stop()
    st.isaltfarming = true
    st.farmalive = true

    local o = CFrame.new(0, 0, -2.5)
    conns:add("FarmTP", rs.Heartbeat:Connect(function()
        if st.unloaded or not st.isaltfarming then return end
        local target = plrs:FindFirstChild(st.farmtargetname)
        if target and target.Character then
            pcall(function() farm.lockcframe(target.Character, getchar(), o, true) end)
        end
    end))

    local t = task.spawn(function()
        while st.isaltfarming and not st.unloaded do
            if st.farmalive and getchar() then
                pcall(function() if replicatesignal then replicatesignal(lp.Kill) end end)
            end
            task.wait(1)
        end
    end)
    conns:trackthread(t)

    if lp.Character then farm.triggerinitialhpdrop(lp.Character) end
    conns:add("FarmAlt", lp.CharacterAdded:Connect(function(c)
        if st.unloaded or not st.isaltfarming then return end
        st.farmalive = false
        c:WaitForChild("HumanoidRootPart", 5)
        task.wait(1.5)
        st.farmalive = true
        farm.triggerinitialhpdrop(c)
    end))
end

