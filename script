local conns = { _list = {}, _threads = {} }

function conns:add(n, c)
    if self._list[n] then pcall(function() self._list[n]:Disconnect() end) end
    self._list[n] = c
    return c
end

function conns:remove(n)
    if self._list[n] then
        pcall(function() self._list[n]:Disconnect() end)
        self._list[n] = nil
    end
end

function conns:trackthread(t)
    self._threads[t] = true
    return t
end

function conns:disconnectall()
    for _, c in pairs(self._list) do pcall(function() c:Disconnect() end) end
    for t, _ in pairs(self._threads) do pcall(function() task.cancel(t) end) end
    self._list = {}
    self._threads = {}
end

local function getchar() return lp.Character end

local function togglehitbox(s)
    local ok, ctrl = pcall(function()
        return require(lp.PlayerScripts.Controllers.Combat.HitboxController)
    end)
    if not ok then return end

    if s then
        if not st.hitboxoriginal then
            st.hitboxoriginal = ctrl.SphereHitbox
            ctrl.SphereHitbox = function(p1, p2, p3, p4)
                return st.hitboxoriginal(p1, p2, p3, 60)
            end
        end
    else
        if st.hitboxoriginal then
            ctrl.SphereHitbox = st.hitboxoriginal
            st.hitboxoriginal = nil
        end
    end
end

local farm = {}

function farm.lockcframe(bchar, mchar, o, look)
    if not st.farmalive then return end
    if not (bchar and mchar) then return end
    local broot = bchar:FindFirstChild("HumanoidRootPart")
    local mroot = mchar:FindFirstChild("HumanoidRootPart")
    local mhum = mchar:FindFirstChild("Humanoid")
    if not (broot and mroot and mhum and mhum.Health > 0) then return end

    local j = Vector3.new(math.random(-10,10)/100, 0, math.random(-10,10)/100)
    local cf
    if look then
        local pos = (broot.CFrame * o).Position + j
        cf = CFrame.lookAt(pos, broot.Position)
    else
        cf = (broot.CFrame * o) + j
    end
    mchar:PivotTo(cf)
    mroot.AssemblyLinearVelocity = Vector3.zero
    mroot.AssemblyAngularVelocity = Vector3.zero
end

function farm.firedynamicm1()
    local c = workspace.Characters:FindFirstChild(lp.Name) or getchar()
    if not c then return end
    local m = c:GetAttribute("Moveset")
    if not m then return end
    local s = m .. "Service"
    local ok, rem = pcall(function()
        return rs2.Knit.Knit.Services:FindFirstChild(s).RE.Activated
    end)
    if ok and rem then rem:FireServer(false) end
end

function farm.triggerinitialhpdrop(c)
    if not c or not st.farmalive then return end
    task.delay(0.1, function()
        if st.unloaded then return end
        local m = c:FindFirstChild("Moveset")
        local mv = m and m:FindFirstChild("Resolute Slash")
        local r = rs2:FindFirstChild("Knit")
        if mv and r then
            pcall(function() r.Knit.Services.ResoluteSlashService.RE.Activated:FireServer(mv, c) end)
        end
    end)
end

